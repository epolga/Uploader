<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings file="App.private.config">
    <add key="S3BucketName" value="cross-stitch-designs"/>
    <add key="S3PhotoPrefix" value="photos"/>
    <add key="SiteBaseUrl" value="https://cross-stitch.com" />
    <add key="UsersTableName" value="CrossStitchUsers"/>
    <add key="UserEmailAttribute" value="Email"/>
    <add key="PinterestClientId" value="1535483"/>
    <add key="PinterestAuthUrl" value="https://www.pinterest.com/oauth/"/>
    <add key="PinterestTokenUrl" value="https://api.pinterest.com/v5/oauth/token"/>
    <add key="PinterestPinsUrl" value="https://api.pinterest.com/v5/pins"/>
    <add key="PinterestRedirectUri" value="http://localhost:8080/callback"/>
    <add key="PinterestScope" value="pins:read pins:write boards:read boards:write ads:read"/>
    <add key="PinterestBoardId" value ="257127528664615140"/>
    <add key="PinterestLinkUrl" value="https://cross-stitch.com"/>
    <add key="ElasticBeanstalkEnvironmentName" value="cross-stitch-com-env-clone"/>
    <add key="UnsubscribeBaseUrl" value="https://cross-stitch.com/unsubscribe"/>
    <!--
      Email templates are read directly from the sibling cross-stitch-platform-docs
      repo so edits there are picked up by the next "Reload Email Template" click
      without a project rebuild. %CROSS_STITCH% expands to the CROSS_STITCH
      environment variable; if that variable is not set, the app falls back to
      "D:\ann\Git" (see CrossStitchRootDefault in MainWindow.xaml.cs). If you ever
      relocate all three sibling repos (Uploader, cross-stitch-platform-docs,
      cross-stitch) to a different common parent, set CROSS_STITCH to that parent
      and these paths keep working unchanged. The Templates/*.txt files under
      this project are kept as snapshots / fallback only — they are no longer the
      source of truth.
    -->
    <add key="HtmlEmailTemplatePath" value="%CROSS_STITCH%\cross-stitch-platform-docs\docs\uploader\HtmlEmailTemplate.txt"/>
    <add key="TextEmailTemplatePath" value="%CROSS_STITCH%\cross-stitch-platform-docs\docs\uploader\TextEmailTemplate.txt"/>
  </appSettings>
</configuration>
